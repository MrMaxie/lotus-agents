# Optional Lotus Agents path overrides.
# Copy this file to lotus.config.yaml only when a repository uses different
# directory names than the default Lotus Agents conventions.
# See lotus.config.schema.json for the machine-readable schema.

docs_root: docs
specs_dir: docs/specs
meetings_dir: docs/meetings

local_root: .local
local_agents_file: .local/AGENTS.md
context_file: .local/context.md

local_docs_root: .local/docs
local_specs_dir: .local/docs/specs
local_meetings_dir: .local/docs/meetings

issues_dir: .local/issues
issue_notes_dir: .local/issues-notes
questions_dir: .local/questions
runs_dir: .local/runs
reviews_dir: .local/reviews
pr_notes_dir: .local/pr-notes

# Use "auto" to detect main or master unless the human explicitly sets a base
# branch for the current run.
default_branch: auto
