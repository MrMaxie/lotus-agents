{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lotus Agents Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "docs_root": {
      "type": "string",
      "description": "Committed docs tree root.",
      "default": "docs"
    },
    "specs_dir": {
      "type": "string",
      "description": "Committed specs directory.",
      "default": "docs/specs"
    },
    "meetings_dir": {
      "type": "string",
      "description": "Committed meetings directory.",
      "default": "docs/meetings"
    },
    "local_root": {
      "type": "string",
      "description": "Local execution memory root.",
      "default": ".local"
    },
    "local_agents_file": {
      "type": "string",
      "description": "Local override rules file.",
      "default": ".local/AGENTS.md"
    },
    "context_file": {
      "type": "string",
      "description": "Local execution context file.",
      "default": ".local/context.md"
    },
    "local_docs_root": {
      "type": "string",
      "description": "Local-only docs root.",
      "default": ".local/docs"
    },
    "local_specs_dir": {
      "type": "string",
      "description": "Local-only specs directory.",
      "default": ".local/docs/specs"
    },
    "local_meetings_dir": {
      "type": "string",
      "description": "Local-only meetings directory.",
      "default": ".local/docs/meetings"
    },
    "issues_dir": {
      "type": "string",
      "description": "Issue files directory.",
      "default": ".local/issues"
    },
    "issue_notes_dir": {
      "type": "string",
      "description": "Issue notes directory.",
      "default": ".local/issues-notes"
    },
    "questions_dir": {
      "type": "string",
      "description": "Questions directory.",
      "default": ".local/questions"
    },
    "runs_dir": {
      "type": "string",
      "description": "General run logs directory.",
      "default": ".local/runs"
    },
    "reviews_dir": {
      "type": "string",
      "description": "Review artifacts directory.",
      "default": ".local/reviews"
    },
    "pr_notes_dir": {
      "type": "string",
      "description": "PR notes directory.",
      "default": ".local/pr-notes"
    },
    "default_branch": {
      "description": "Concrete branch name or auto detection.",
      "oneOf": [
        {
          "const": "auto"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ],
      "default": "auto"
    }
  }
}
